generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ROLES {
  SuperAdmin
  Trainer
  Customer
}

model Role {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  ROLES  @unique
  users User[]
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName  String?
  lastName   String?
  email      String   @unique

  stepGoal   StepGoal?
  weightGoal WeightGoal?
  stepEntries StepEntry[]
  weightEntries WeightEntry[]

  assignedWorkoutRelations WorkoutTrainerAssignment[]

  planId String? @db.ObjectId
  plan   Plan?   @relation("TrainerPlan", fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions Subscription[]

  phone      String?
  password   String?
  provider   String   @default("LOCAL")
  providerId String?
  roleId     String
  isActive   Boolean  @default(false)
  phoneVerified Boolean @default(false)
  fcmToken   String?
  gender     Gender?

  role       Role     @relation(fields: [roleId], references: [id])
  otps       Otp[]    // Added back-relation to Otp
  specialities UserSpeciality[]

  isPremiumMember   Boolean @default(false)

  trainerWeeklyAvailabilities TrainerWeeklyAvailability[] @relation("Trainer_Weekly")
  trainerDailyAvailabilities TrainerDailyAvailability[] @relation("Trainer_Daily")
  trainerTimeSlots           TrainerTimeSlot[]           @relation("Trainer_Slot")
  trainerBookings            TrainerBooking[]            @relation("Trainer_Booking") // As trainer in bookings
  customerBookings           TrainerBooking[]            @relation("Customer_Booking") // As customer in bookings

  // Added back-relations for AssignedCustomer
  assignedCustomersAsCustomer AssignedCustomer[] @relation("AssignedCustomer_Customer")
  assignedCustomersAsTrainer  AssignedCustomer[] @relation("AssignedCustomer_Trainer")

  userProfileDetails UserProfileDetail[] @relation("UserProfileDetailToUser")
  workoutVideos   WorkoutVideo[] @relation("UserWorkoutVideos")

  trainerVideos   TrainerVideo[]

  assignedVideos TrainerVideoAssignment[]

  plans      Plan[]   @relation("UserPlans")

  trainerRequests TrainerRequest[] @relation("CustomerRequests") // As the customer who made the request
  trainerApplications TrainerRequest[] @relation("TrainerRequests") // As the trainer receiving requests

  notifications Notification[] // Opposite relation: user has many notifications

  userDevices UserDevice[] // Opposite relation: user has many user devices
  questionnaire Questionnaire?
  journalEntries JournalEntry[]

  // Opposite relation: user has many chat conversations as trainer and as customer
  chatConversationsAsTrainer   ChatConversation[] @relation("ChatConversation_Trainer")
  chatConversationsAsCustomer  ChatConversation[] @relation("ChatConversation_Customer")

  // Opposite relation: user has many chat messages as sender and as receiver
  sentChatMessages     ChatMessage[] @relation("ChatMessage_Sender")
  receivedChatMessages ChatMessage[] @relation("ChatMessage_Receiver")

  // Opposite relation: user has many reviews as trainer and as customer
  receivedReviewsAsTrainer   Review[] @relation("Review_Trainer")
  receivedReviewsAsCustomer  Review[] @relation("Review_Customer")

  customerQuestionaires CustomerQuestionaire[]

  createdAt  DateTime @default(now())
}

model UserProfileDetail {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  address         String?
  bio             String?
  hostGymName     String?
  hostGymAddress  String?
  avatarUrl       String?
  avatarPublicId  String?
  dob             DateTime?
  gender          String?
  socialMediaLinks String[]

  user            User     @relation("UserProfileDetailToUser", fields: [userId], references: [id], onDelete: Cascade )

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Otp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UserSpeciality {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  specialityId  String   @db.ObjectId
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  speciality    Speciality @relation("Speciality_UserSpeciality", fields: [specialityId], references: [id], onDelete: Cascade)

  @@unique([userId, specialityId])
}


model TrainerWeeklyAvailability {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  trainerId            String   @db.ObjectId
  weekStartDate        DateTime
  weekEndDate          DateTime
  requiredMinutes      Int      @default(2700)   //45 * 60
  totalBookedMinutes   Int      @default(0)
  isCompleted          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  trainer              User     @relation("Trainer_Weekly", fields: [trainerId], references: [id], onDelete: Cascade)
  dailyAvailabilities  TrainerDailyAvailability[] @relation("Week_Daily")
}

model TrainerDailyAvailability {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  trainerWeekId     String   @db.ObjectId
  trainerId         String   @db.ObjectId
  date              DateTime
  dayOfWeek         String

  isAvailable       Boolean   @default(false)
  totalDayMinutes   Int

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trainer           User                        @relation("Trainer_Daily", fields: [trainerId], references: [id], onDelete: Cascade)
  trainerWeek       TrainerWeeklyAvailability   @relation("Week_Daily", fields: [trainerWeekId], references: [id], onDelete: Cascade)
  timeSlots         TrainerTimeSlot[]           @relation("Daily_TimeSlot")
}

enum SlotType {
  ALTERNATIVE
  PEAK
}

model TrainerTimeSlot {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  dailyAvailabilityId String   @db.ObjectId
  trainerId           String   @db.ObjectId
  date                DateTime
  startTime           DateTime
  endTime             DateTime
  slotType            SlotType
  durationMinutes     Int
  isBooked            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  timeSlotId          String?  @db.ObjectId



  dailyAvailability   TrainerDailyAvailability @relation("Daily_TimeSlot", fields: [dailyAvailabilityId], references: [id], onDelete: Cascade)
  trainer             User                    @relation("Trainer_Slot", fields: [trainerId], references: [id], onDelete: Cascade)
  bookings            TrainerBooking[]        @relation("TimeSlot_Booking")
  timeSlot            TimeSlot?               @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@index([date])
}

enum BookingStatus {
  PENDING
  ATTENDED
  NOTATTENDED
}

model TrainerBooking {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId            String   @db.ObjectId
  trainerId             String   @db.ObjectId
  timeSlotId            String   @db.ObjectId
  isCancelled           Boolean  @default(false)
  remarks               String?
  bookingStatus         BookingStatus @default(PENDING)

  personalTrainingSession String?

  originalTimeSlotId    String?  @db.ObjectId
  rescheduledCount      Int      @default(0)
  lastRescheduledAt     DateTime?
  accolades             Int[]   @default([])

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customer              User                @relation("Customer_Booking", fields: [customerId], references: [id], onDelete: Cascade)
  trainer               User                @relation("Trainer_Booking", fields: [trainerId], references: [id], onDelete: Cascade)
  timeSlot              TrainerTimeSlot     @relation("TimeSlot_Booking", fields: [timeSlotId], references: [id], onDelete: Cascade)
}

model AssignedCustomer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String   @db.ObjectId
  trainerId   String   @db.ObjectId

  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime?

  customer    User     @relation("AssignedCustomer_Customer", fields: [customerId], references: [id], onDelete: Cascade)
  trainer     User     @relation("AssignedCustomer_Trainer", fields: [trainerId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  
  updatedAt           DateTime @updatedAt
  @@unique([customerId, trainerId])
  @@index([customerId, isActive])
  @@index([trainerId, isActive])
}


model Speciality {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  createdBy String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userSpecialities UserSpeciality[] @relation("Speciality_UserSpeciality")
}

model TimeSlot {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  date                DateTime
  startTime           DateTime
  endTime             DateTime
  slotType            SlotType @default(PEAK)
  durationMinutes     Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String @db.ObjectId

  trainerTimeSlots    TrainerTimeSlot[]

  @@index([date])
}

enum VideoUploadStatus {
  PROCESSING 
  READY 
  FAILED
}

model WorkoutVideo {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String?
  tags         String[]
  videoUrl     String?
  thumbnailUrl String?
  publicId     String?
  status       VideoUploadStatus   @default(PROCESSING)
  uploadedBy   String   @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploader     User @relation("UserWorkoutVideos", fields: [uploadedBy], references: [id])
  assignments  WorkoutTrainerAssignment[]
}

model TrainerVideo {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  tags        String[]

  videoLink   String
  thumbnail   String

  trainerId   String   @db.ObjectId
  trainer     User     @relation(fields: [trainerId], references: [id])

  assignments TrainerVideoAssignment[]   // ✅ ADD THIS

  createdAt   DateTime @default(now())
}

model TrainerVideoAssignment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  videoId   String   @db.ObjectId
  clientId  String   @db.ObjectId

  assignedAt DateTime @default(now())

  video     TrainerVideo @relation(fields: [videoId], references: [id])
  client    User         @relation(fields: [clientId], references: [id])
}

model Plan {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  price      Float
  features   String[]
  isPopular  Boolean  @default(false)
  createdBy  String   @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  assignedTrainers User[] @relation("TrainerPlan")

  subscriptions Subscription[]

  creator    User     @relation("UserPlans", fields: [createdBy], references: [id])
}

enum TrainerRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TrainerRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String   @db.ObjectId
  trainerId   String   @db.ObjectId
  message     String?
  status      TrainerRequestStatus @default(PENDING)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    User @relation("CustomerRequests", fields: [customerId], references: [id])
  trainer     User @relation("TrainerRequests", fields: [trainerId], references: [id])
}

enum NotificationType {
  TRAINER_REQUEST
  BOOKING
  REMINDER
}
model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  message   String
  type      NotificationType
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])
}

model UserDevice {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  fcmToken  String
  device    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BlacklistedToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Questionnaire {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId

  userId              String   @unique @db.ObjectId
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientName          String
  age                 Int
  heightCm            Int
  weightKg            Float
  dietaryRestrictions String?
  goals               String?
  medicalHistory      String?
  exerciseExperience  String?
  availability        String?
  trainingPreferences String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}


model JournalEntry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  photoUrl    String?  // URL to photo (optional)
  videoUrl    String?  // URL to video (optional)

  note        String?  // Today's note or progress
  date        DateTime?

  isPrivate   Boolean  @default(false)

  energy              Int
  physicalReadiness   Int
  motivation          Int
  stressLevel         Int
  mentalFitness       Int
  dayNumber           Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}


// Chat schema
enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model ChatConversation {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String   @unique
  trainerId       String   @db.ObjectId
  customerId      String   @db.ObjectId

  lastMessage     String?
  lastMessageTime DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trainer   User @relation("ChatConversation_Trainer", fields: [trainerId], references: [id])
  customer  User @relation("ChatConversation_Customer", fields: [customerId], references: [id])

  messages  ChatMessage[]

  @@index([trainerId])
  @@index([customerId])
}

model ChatMessage {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String
  senderId        String   @db.ObjectId
  receiverId      String   @db.ObjectId

  message         String?
  fileUrl         String?

  type            MessageType
  status          MessageStatus @default(SENT)

  createdAt       DateTime @default(now())

  conversation    ChatConversation @relation(fields: [conversationId], references: [conversationId])

  sender          User @relation("ChatMessage_Sender", fields: [senderId], references: [id])
  receiver        User @relation("ChatMessage_Receiver", fields: [receiverId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}


enum ReviewType {
  BUSINESS
  TRAINER
}

model Review {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  trainerId    String?   @db.ObjectId
  customerId   String?    @db.ObjectId
  rating       Int
  review       String?
  type         ReviewType
  createdAt    DateTime  @default(now())

  // Relations
  trainer      User?     @relation("Review_Trainer", fields: [trainerId], references: [id])
  customer     User?      @relation("Review_Customer", fields: [customerId], references: [id])

  @@unique([trainerId, customerId, type])
  @@index([customerId])
  @@index([trainerId])
}


model CustomerQuestionaire {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  clientId  String   @db.ObjectId
  client    User     @relation(fields: [clientId], references: [id])

  clientName   String?
  dateOfBirth  DateTime?
  dateCompleted DateTime?

  heartCondition                 Boolean
  chestPainDuringActivity        Boolean
  chestPainLastMonth             Boolean
  dizzinessOrLossOfConsciousness Boolean
  boneOrJointProblem             Boolean
  bloodPressureMedication        Boolean
  otherReasonNotToExercise       Boolean
  pregnancyOrRecentBirth         Boolean
  chronicMedicalCondition        Boolean

  clientSignature   String?
  clientSignedDate  DateTime?

  trainerName       String?
  trainerSignature  String?
  trainerSignedDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StepGoal {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  goal      Int
  reminder  String   // "20:00"
  notify    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model WeightGoal {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  goal      Float
  reminder  String
  notify    Boolean  @default(true) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model StepEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  steps     Int
  date      DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

 @@index([userId, date])
}

model WeightEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  weight    Float
  date      DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model WorkoutTrainerAssignment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  workoutId  String   @db.ObjectId
  trainerId  String   @db.ObjectId

  assignedAt DateTime @default(now())

  workout    WorkoutVideo @relation(fields: [workoutId], references: [id])
  trainer    User         @relation(fields: [trainerId], references: [id])

  @@unique([workoutId, trainerId])
}

model Subscription {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  planId     String   @db.ObjectId

  status     String   // ACTIVE, CANCELLED
  startDate  DateTime @default(now())
  endDate    DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  plan       Plan     @relation(fields: [planId], references: [id])
}